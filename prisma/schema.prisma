// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MANAGEMENT & ROLES
// ============================================

enum UserRole {
  ADMIN       // Администратор системы
  CLUB_ADMIN  // Администратор фитнес-клуба
  TRAINER     // Тренер
  CLIENT      // Клиент/Пользователь
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          UserRole  @default(CLIENT)
  avatar        String?
  phone         String?
  dateOfBirth   DateTime?
  gender        String?   // male, female, other
  
  // Физические параметры
  height        Float?    // в см
  weight        Float?    // в кг
  
  // Медицинская информация
  contraindications String? // JSON строка с противопоказаниями
  chronicDiseases   String? // JSON строка с хроническими заболеваниями
  medications       String? // Принимаемые лекарства
  
  // Цели
  fitnessGoal   String?   // weight_loss, muscle_gain, endurance, rehabilitation, maintenance
  targetWeight  Float?    // Целевой вес
  activityLevel String?   // sedentary, light, moderate, active, very_active
  
  // Настройки носимых устройств
  connectedDevices String? // JSON: ["apple_watch", "samsung_health", "huawei_health"]
  healthKitSync    Boolean @default(false)
  healthConnectSync Boolean @default(false)
  
  // Связи
  clubId        String?
  club          Club?     @relation("ClubMembers", fields: [clubId], references: [id])
  trainerId     String?
  trainer       User?     @relation("TrainerClients", fields: [trainerId], references: [id])
  clients       User[]    @relation("TrainerClients")
  trainerClubId String?
  trainerClub   Club?     @relation("ClubTrainers", fields: [trainerClubId], references: [id])
  
  // Данные
  biometricData     BiometricData[]
  trainingPrograms  TrainingProgram[]
  achievements      UserAchievement[]
  trainingSessions  TrainingSession[]
  notifications     Notification[]
  riskAssessments   RiskAssessment[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================
// FITNESS CLUB MANAGEMENT
// ============================================

model Club {
  id            String    @id @default(cuid())
  name          String
  address       String?
  phone         String?
  email         String?
  description   String?
  logo          String?
  
  // Связи
  members       User[]    @relation("ClubMembers")
  equipment     Equipment[]
  trainers      User[]    @relation("ClubTrainers")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Equipment {
  id            String    @id @default(cuid())
  name          String
  category      String    // cardio, strength, flexibility, other
  description   String?
  imageUrl      String?
  isAvailable   Boolean   @default(true)
  
  clubId        String
  club          Club      @relation(fields: [clubId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================
// BIOMETRIC DATA (from wearable devices)
// ============================================

model BiometricData {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  
  // Источник данных
  source        String    // apple_watch, samsung_health, huawei_health, amazfit, manual
  
  // Основные метрики
  timestamp     DateTime  @default(now())
  
  // Сердечно-сосудистая система
  heartRate         Int?    // ударов в минуту
  heartRateVariability Int? // HRV в мс
  restingHeartRate  Int?    // Пульс в покое
  bloodPressureSystolic  Int?    // Систолическое давление
  bloodPressureDiastolic Int?    // Диастолическое давление
  
  // ЭКГ данные
  ecgData       String?   // JSON с данными ЭКГ
  ecgAnalysis   String?   // Результат анализа ЭКГ
  
  // Дыхательная система
  spO2          Int?      // Насыщение кислородом (%)
  respiratoryRate Int?    // Частота дыхания
  
  // Температура
  bodyTemperature Float?  // Температура тела
  
  // Активность
  steps             Int?      // Шаги за день
  distance          Float?    // Дистанция в км
  caloriesBurned    Int?      // Сожженные калории
  activeMinutes     Int?      // Минуты активности
  floorsClimbed     Int?      // Этажи
  
  // Сон
  sleepDuration     Int?      // Длительность сна в минутах
  sleepQuality      Int?      // Качество сна 1-100
  deepSleepDuration Int?      // Глубокий сон в минутах
  remSleepDuration  Int?      // REM сон в минутах
  sleepStartTime    DateTime? // Время начала сна
  sleepEndTime      DateTime? // Время пробуждения
  
  // Стресс
  stressLevel       Int?      // Уровень стресса 1-100
  
  // Тренировка
  workoutType       String?   // running, cycling, swimming, etc.
  workoutDuration   Int?      // Длительность тренировки в минутах
  workoutIntensity  String?   // low, moderate, high
  
  // Дополнительные данные (JSON)
  rawData           String?   // Сырые данные с устройства
  
  createdAt     DateTime  @default(now())
  
  @@index([userId, timestamp])
  @@index([userId, source])
}

// ============================================
// TRAINING PROGRAMS
// ============================================

model TrainingProgram {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  
  // Основная информация
  name          String
  description   String?
  goal          String    // weight_loss, muscle_gain, endurance, rehabilitation
  difficulty    String    // beginner, intermediate, advanced
  
  // Длительность
  startDate     DateTime
  endDate       DateTime
  durationWeeks Int
  
  // AI-генерация
  isAiGenerated Boolean   @default(false)
  generationModel String? // Какая модель сгенерировала
  basedOnData   String?   // На каких данных основана
  
  // Статус
  status        String    @default("active") // active, completed, paused, cancelled
  progress      Int       @default(0) // Процент выполнения 0-100
  
  // Упражнения
  exercises     ProgramExercise[]
  
  // Связь с тренировками
  sessions      TrainingSession[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([userId, status])
}

model ProgramExercise {
  id            String    @id @default(cuid())
  programId     String
  program       TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  
  // Информация об упражнении
  name          String
  category      String    // strength, cardio, flexibility, balance
  muscleGroups  String    // JSON: ["chest", "triceps", "shoulders"]
  description   String?
  videoUrl      String?
  imageUrl      String?
  
  // Параметры
  sets          Int?
  reps          Int?
  duration      Int?      // в секундах
  restTime      Int?      // отдых в секундах
  weight        Float?    // вес в кг
  
  // День и неделя
  weekNumber    Int       // Неделя программы
  dayOfWeek     Int       // День недели 1-7
  
  // Альтернативы для разных уровней
  alternativeExercise String? // ID альтернативного упражнения
  
  order         Int       // Порядок выполнения
  
  createdAt     DateTime  @default(now())
  
  @@index([programId, weekNumber, dayOfWeek])
}

// ============================================
// TRAINING SESSIONS
// ============================================

model TrainingSession {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  programId     String?
  program       TrainingProgram? @relation(fields: [programId], references: [id])
  
  // Информация о тренировке
  startTime     DateTime
  endTime       DateTime?
  duration      Int?      // в минутах
  
  // Данные тренировки
  workoutType   String?
  caloriesBurned Int?
  avgHeartRate  Int?
  maxHeartRate  Int?
  
  // Оценка
  rating        Int?      // 1-5
  notes         String?
  
  // Упражнения на сессии
  exerciseLogs  ExerciseLog[]
  
  createdAt     DateTime  @default(now())
  
  @@index([userId, startTime])
}

model ExerciseLog {
  id            String    @id @default(cuid())
  sessionId     String
  session       TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  exerciseName  String
  category      String?
  
  // Выполнение
  setsCompleted Int?
  repsCompleted Int?
  weightUsed    Float?
  duration      Int?      // в секундах
  
  // Субъективные ощущения
  difficulty    Int?      // 1-10 scale (RPE)
  notes         String?
  
  createdAt     DateTime  @default(now())
}

// ============================================
// RISK ASSESSMENT & HEALTH ANALYSIS
// ============================================

model RiskAssessment {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  
  // Классификация
  fitnessClass  String    // excellent, good, moderate, needs_attention, at_risk
  classificationConfidence Float? // Уверенность модели 0-1
  
  // Оценки рисков
  cardiovascularRisk  String? // low, moderate, high, very_high
  metabolicRisk       String?
  injuryRisk          String?
  overtrainingRisk    String?
  
  // Рекомендации
  recommendations String? // JSON с рекомендациями
  
  // Данные на момент оценки
  basedOnBiometricData String? // JSON с усредненными данными
  
  createdAt     DateTime  @default(now())
  
  @@index([userId, createdAt])
}

// ============================================
// ACHIEVEMENTS & GAMIFICATION
// ============================================

model Achievement {
  id            String    @id @default(cuid())
  name          String
  description   String
  category      String    // fitness, consistency, social, special
  icon          String?   // emoji или URL изображения
  points        Int       @default(10)
  
  // Условия получения
  criteria      String    // JSON с условиями
  
  // Уровни
  maxLevel      Int       @default(1)
  
  // Связи
  userAchievements UserAchievement[]
  
  createdAt     DateTime  @default(now())
}

model UserAchievement {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  
  level         Int       @default(1)
  progress      Int       @default(0) // Прогресс до следующего уровня
  unlockedAt    DateTime  @default(now())
  
  @@unique([userId, achievementId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  
  type          String    // reminder, achievement, alert, recommendation
  title         String
  message       String
  
  isRead        Boolean   @default(false)
  readAt        DateTime?
  
  // Дополнительные данные
  data          String?   // JSON
  
  createdAt     DateTime  @default(now())
  
  @@index([userId, isRead, createdAt])
}

// ============================================
// EXERCISE LIBRARY
// ============================================

model ExerciseLibrary {
  id            String    @id @default(cuid())
  name          String
  category      String    // strength, cardio, flexibility, balance, sports
  muscleGroups  String    // JSON
  equipment     String?   // Необходимое оборудование
  difficulty    String    // beginner, intermediate, advanced
  
  description   String?
  instructions  String?   // JSON с шагами
  videoUrl      String?
  imageUrl      String?
  
  // Метрики
  caloriesPerMinute Int?
  
  // Безопасность
  contraindications String? // JSON с противопоказаниями
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
