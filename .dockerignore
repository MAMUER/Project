# ==========================================
# Fitness Platform - Docker Ignore
# ==========================================
# Исключает файлы из Docker build context.
# НЕ влияет на ML-сервисы (у них свой .dockerignore).

# Git
.git
.gitignore

# IDE
.vscode
.vs
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Go — локальные артефакты (собираем внутри Docker)
*.exe
*.test
*.out
bin/

# Logs
logs/
*.log

# Environment — секреты в образе = уязвимость!
.env
.env.local
.env.*.local
!.env.example

# ML models и датасеты — большие файлы
# models/ НЕ исключён из корневого .dockerignore, т.к. ML Dockerfile
# нуждается в COPY models/. CI пропускает ML-сборку если файлов нет.
datasets/

# Documentation
docs/
*.md
!README.md

# Security files — не должны попадать в образ
.gitleaks.toml
SECURITY.md

# Temporary files
tmp/
temp/
*.tmp

# Python — не нужен в Go-образах
__pycache__/
*.pyc
*.pyo
venv/
venv_ml/
.venv/

# Kubernetes — манифесты не нужны в контейнере
configs/k8s/

# CI/CD
.github/

# Tests
*_test.go
