# FitPulse Environment Variables Configuration
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# ==========================================
# Database Configuration
# ==========================================
POSTGRES_USER=fitpulse_user
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
POSTGRES_DB=fitpulse
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fitpulse
DB_SSLMODE=disable

# ==========================================
# Redis Configuration
# ==========================================
REDIS_ADDR=redis:6379
REDIS_DB=0
REDIS_PASSWORD=<CHANGE_ME_REDIS_PASSWORD>

# ==========================================
# RabbitMQ Configuration
# ==========================================
RABBITMQ_USER=fitpulse
RABBITMQ_PASS=<CHANGE_ME_RABBITMQ_PASSWORD>
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# ==========================================
# JWT & Authentication
# ==========================================
# Generate with: openssl rand -base64 64
JWT_SECRET=<CHANGE_ME_JWT_SECRET_MIN_32_CHARS>

# ==========================================
# Service Ports
# ==========================================
AUTH_PORT=8081
AUTH_GRPC_PORT=50051
TASKS_PORT=8082
GATEWAY_PORT=8080

# ==========================================
# Inter-Service Communication
# ==========================================
AUTH_GRPC_ADDR=auth:50051
USER_SERVICE_ADDR=user-service:50051
BIOMETRIC_SERVICE_ADDR=biometric-service:50052
TRAINING_SERVICE_ADDR=training-service:50053

# ==========================================
# ML Services
# ==========================================
ML_CLASSIFIER_URL=http://ml-classifier:8001
ML_GENERATOR_URL=http://ml-generator:8002
MODEL_PATH=/app/models/classifier.keras
SCALER_PATH=/app/models/scaler.pkl
GENERATOR_PATH=/app/models/generator.h5

# ==========================================
# Email Configuration (SMTP)
# ==========================================
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=<CHANGE_ME_EMAIL_USER>
SMTP_PASSWORD=<CHANGE_ME_EMAIL_PASSWORD>
SMTP_FROM=fitpulse@yandex.ru

# ==========================================
# Response Signing
# ==========================================
RESPONSE_SIGNING_SECRET=<CHANGE_ME_SIGNING_SECRET_MIN_32_CHARS>

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_PER_SECOND=10
RATE_LIMIT_BURST=20
